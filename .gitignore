# Maven
target/
build/

# IDE - Eclipse / Pleiades
.classpath
.project
.settings/
bin/
# Eclipse の bin/ は除外したいが、研修ハーネスの guard スクリプトは追跡対象。
!containers/codex-devbox/bin/
!containers/codex-devbox/bin/**
# かんたんセットアップの .bat が委譲する PowerShell 実体 (bin/*.ps1) も追跡対象。
!かんたんセットアップ/bin/
!かんたんセットアップ/bin/**
# EasySetupForMacOS の .command が委譲する bash 実体 (bin/*.sh) も追跡対象。
!EasySetupForMacOS/bin/
!EasySetupForMacOS/bin/**
.metadata
*.launch

