# =========================================================================
# 社内つぶやきボード 環境変数テンプレート
# 使い方: このファイルを .env にコピーし、値を埋めて使用する。
#   cp dotenv.example .env
# .env は .gitignore で除外されているため、コミットされない。
# (このファイル名が dotenv.example なのは、.env.example が権限ポリシーで
#  扱いづらいケースを想定した代替命名。)
# =========================================================================

# --- OpenAI / Codex --------------------------------------------------------
# 各受講者個別の OpenAI API キー (sk- で始まる)
# 取得方法: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# --- Oracle DB XE (Podman) -------------------------------------------------
# SYS / SYSTEM の管理者パスワード
ORACLE_PWD=Training#2026
# アプリ用ユーザのパスワード
ORACLE_APP_PWD=butsubutsu_pw

# --- Spring Boot プロファイル ----------------------------------------------
# local: Oracle XE (Podman) に接続
# h2:    H2 メモリ DB (Oracle 起動なしで動かしたい時)
SPRING_PROFILES_ACTIVE=local
