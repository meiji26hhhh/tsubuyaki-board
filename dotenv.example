# =========================================================================
# 社内つぶやきボード 環境変数テンプレート
# 使い方: このファイルを .env にコピーし、値を埋めて使用する。
#   cp dotenv.example .env
# .env は .gitignore で除外されているため、コミットされない。
# (このファイル名が dotenv.example なのは、.env.example が権限ポリシーで
#  扱いづらいケースを想定した代替命名。)
# =========================================================================

# --- Oracle DB XE (Podman) -------------------------------------------------
# SYS / SYSTEM の管理者パスワード
ORACLE_PWD=Training#2026
# アプリ用ユーザのパスワード
ORACLE_APP_PWD=tsubuyaki_pw

# 注: Spring Boot は .env を読まないため、プロファイル切替はこのファイルでは
# 行えない。`./mvnw -Ph2 spring-boot:run` または
# `SPRING_PROFILES_ACTIVE=h2 ./mvnw spring-boot:run` のようにコマンド側で指定する。
